# =============================================================================
# .dockerignore — Excluye archivos innecesarios del contexto de build Docker
# =============================================================================

# Git
.git/
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
ENV/
env/

# Entorno
.env
.env.*
*.env

# Datos pesados (no se necesitan en runtime del API)
data/raw/
data/processed/
# Nota: los pesos del modelo BETO (beto-imdb-finetuned) SÍ se necesitan en runtime

# BD SQLite (se monta como volumen, no se copia en imagen)
*.db
*.sqlite
*.sqlite3
backend/*.db

# Logs
logs/
*.log

# Archivos de sistema
.DS_Store
**/.DS_Store
*.pid

# Node
node_modules/
frontend/dist/

# Jupyter
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Agent / opencode
.agents/
.opencode/
skills-lock.json

# Documentación raíz (no necesaria en contenedor)
README.md
